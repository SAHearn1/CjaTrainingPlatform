# ── Supabase (Client-side) ────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API → Project URL / anon key
# These values are safe to expose publicly (Row Level Security protects all data).
# They are currently hardcoded in utils/supabase/info.tsx; move them here if you
# want to manage them via environment variables and update that file accordingly.
VITE_SUPABASE_PROJECT_ID=your-supabase-project-id
VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# ── Supabase Edge Function Secrets (Server-side only) ─────────────────────────
# Set these in: Supabase Dashboard → Project Settings → Edge Functions → Secrets
# Do NOT put these in a .env file — they must be set as Supabase secrets.
#
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   (also used as encryption master key)

# ── Stripe (Server-side only) ─────────────────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API Keys → Secret key
# Set as a Supabase Edge Function secret — do NOT put in .env.
#
# STRIPE_SECRET_KEY=sk_live_...

# ── Google Gemini (Server-side only) ──────────────────────────────────────────
# Found in: Google AI Studio → API keys (https://aistudio.google.com)
# Powers the "Rooty" help chatbot. Set as a Supabase Edge Function secret.
#
# GEMINI_API_KEY=AIza...
